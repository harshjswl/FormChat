{
  "info": {
    "name": "Auth Service API",
    "description": "Authentication API with AWS SNS phone verification",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Registration",
      "item": [
        {
          "name": "Send Register OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"+12345678900\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/auth/register/send-otp",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["auth", "register", "send-otp"]
            }
          }
        },
        {
          "name": "Verify Register OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"phone\": \"+12345678900\",\n  \"emailOtp\": \"123456\",\n  \"phoneOtp\": \"654321\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/auth/register/verify",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["auth", "register", "verify"]
            }
          }
        },
        {
          "name": "Resend Register OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"phone\": \"+12345678900\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/auth/register/resend-otp",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["auth", "register", "resend-otp"]
            }
          }
        }
      ]
    },
